{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "moduleResolution": "bundler",

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "ignoreDeprecations": "6.0"
  }
}